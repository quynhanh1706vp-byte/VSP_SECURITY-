# VSP Platform — Environment Variables
# Copy này thành .env và điền giá trị thật
# KHÔNG commit .env vào git

# Required
JWT_SECRET=change-me-minimum-32-chars-random
REDIS_PASSWORD=change-me

# Database (nếu không dùng config.yaml)
# DATABASE_URL=postgres://vsp:vsp@localhost:5432/vsp_go

# Optional integrations
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx
JIRA_TOKEN=xxx
GITHUB_TOKEN=ghp_xxx
PAGERDUTY_KEY=xxx

# Production
SERVER_ENV=production
