# Copy to .env and fill in values
# DO NOT commit .env

ANTHROPIC_API_KEY=sk-ant-...

# JWT primary secret (min 32 chars, used for ISSUING new tokens)
JWT_SECRET=change-me-min-32-chars

# JWT rotation (OPTIONAL — set only during rotation window)
# During a 24h rotation, rename previous JWT_SECRET → JWT_SECRET_OLD,
# generate new value for JWT_SECRET. Old sessions remain valid until
# their tokens expire. After 24h, unset JWT_SECRET_OLD.
# See: docs/JWT_ROTATION_RUNBOOK.md
# JWT_SECRET_OLD=old-secret-during-rotation-only

# JWT TTL (Go duration syntax — 24h, 1h, 30m, etc.)
JWT_TTL=24h

DATABASE_URL=postgres://vsp:password@localhost:5432/vsp
REDIS_URL=redis://localhost:6379
