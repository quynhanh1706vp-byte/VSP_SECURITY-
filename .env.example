# VSP Platform — Environment variables
# Copy sang .env và điền giá trị thật

# Bắt buộc
JWT_SECRET=                    # openssl rand -hex 32
POSTGRES_PASSWORD=vsp          # đổi ở production
REDIS_PASSWORD=VspRedis2026!   # đổi ở production

# Optional
SERVER_ENV=development
ALLOWED_ORIGINS=http://localhost:8922,http://127.0.0.1:8922
ANTHROPIC_API_KEY=             # cho AI Analyst feature
SMTP_PASSWORD=                 # cho email alerts

# SSO (nếu dùng)
# SSO_ENABLED=false
# SSO_PROVIDER=google
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
